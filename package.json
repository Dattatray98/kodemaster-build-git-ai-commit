{
  "name": "@jdattatray.ls/navix",
  "version": "1.1.0",
  "description": "AI-powered git commit message generator",
  "author": "Dattatray Jojewar",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "navix": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/core/index.ts --outdir dist --target=node",
    "dev": "bun run src/core/index.ts",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Dattatray98/Navix.git"
  },
  "homepage": "https://github.com/Dattatray98/Navix",
  "bugs": {
    "url": "https://github.com/Dattatray98/Navix/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "git",
    "ai",
    "cli",
    "ollama",
    "openai",
    "commit",
    "commit-generator",
    "developer-tools",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "ollama": "^0.6.3",
    "openai": "^6.37.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.7.0"
  }
}